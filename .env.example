# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection URL (supports authentication)
# Format: redis://[username:password@]host:port[/db]
# 
# Local Redis (no auth):
# REDIS_URL=redis://localhost:6379/0
#
# Redis Cloud (with auth):
# REDIS_URL=redis://default:your-password@redis-12345.cloud.redislabs.com:12345
#
# Redis Cloud with SSL:
# REDIS_URL=rediss://default:your-password@redis-12345.cloud.redislabs.com:12345
REDIS_URL=redis://default:Dee4WHKTd6NxTlLswzrAkDcQjD3Rjfnx@redis-19891.crce278.sa-east-1-2.ec2.cloud.redislabs.com:19891

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================

# Embedding model (HuggingFace model name)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Embedding dimensions (must match the model)
EMBEDDING_DIM=384

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================

# Default number of search results
DEFAULT_LIMIT=5

# Weight for popularity in scoring (0.0 - 1.0)
POPULARITY_WEIGHT=0.3

# Semantic router distance threshold (currently disabled)
SEMANTIC_ROUTER_DISTANCE_THRESHOLD=0.55

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# FastAPI server settings
APP_HOST=0.0.0.0
APP_PORT=8092

# Debug mode (true/false)
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

